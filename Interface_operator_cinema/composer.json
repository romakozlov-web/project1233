{
    "name": "almaz/cinema-admin",
    "description": "Admin panel for cinema Almaz",
    "type": "project",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Cinema\\": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cinema\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix"
    }
}